<% layout("/layouts/boilerplate") %>


<style>
.policy-hero{
  height:40vh;
  background:linear-gradient(rgba(0,0,0,0.6),rgba(0,0,0,0.6)),
  url('../home.jpeg') center/cover no-repeat;
}

.policy-card{
  background:white;
  border-radius:12px;
  box-shadow: 0 15px 40px rgba(0, 0, 0, 0.444) !important;
}

.policy-card h3{
  color:#333;
  font-weight:600;
}
</style>

<section class="policy-hero text-white text-center d-flex align-items-center">
  <div class="container">
    <h1 class="fw-bold">Privacy Policy & Terms</h1>
    <p>Your trust is important to Majestic Rest Villas</p>
  </div>
</section>

<div class="container my-5">

  <div class="policy-card p-4 mb-4 shadow-sm">
    <h3>Privacy Policy</h3>
    <p>
      At <strong>Majestic Rest Villas (MRV)</strong>, we value your privacy. 
      This policy explains how we collect, use, and protect your personal information 
      when you use our villa booking platform.
    </p>

    <h5 class="mt-3">Information We Collect</h5>
    <ul>
      <li>Name, email address, and contact details.</li>
      <li>Account information when you register.</li>
      <li>Property details submitted by hosts.</li>
      <li>Booking and transaction information.</li>
    </ul>

    <h5 class="mt-3">How We Use Your Information</h5>
    <ul>
      <li>To manage bookings and reservations.</li>
      <li>To verify hosts and property listings.</li>
      <li>To improve user experience and platform security.</li>
      <li>To provide customer support.</li>
    </ul>

    <h5 class="mt-3">Data Protection</h5>
    <p>
      We implement strict security measures to protect user data. 
      Your personal information will never be sold or shared with third parties 
      without your consent except where required by law.
    </p>
  </div>


  <div class="policy-card p-4 mb-4 shadow-sm">
    <h3>Terms & Conditions</h3>

    <h5 class="mt-3">User Responsibilities</h5>
    <ul>
      <li>Users must provide accurate information during registration.</li>
      <li>Users must respect property rules set by hosts.</li>
      <li>Any misuse of the platform may result in account suspension.</li>
    </ul>

    <h5 class="mt-3">Host Responsibilities</h5>
    <ul>
      <li>Hosts must provide valid property documents.</li>
      <li>Listings must accurately describe the property.</li>
      <li>Hosts must maintain property standards and safety.</li>
    </ul>

    <h5 class="mt-3">Bookings and Payments</h5>
    <p>
      All bookings made through MRV are subject to availability and confirmation 
      by the host. MRV acts as a platform connecting guests and hosts and is not 
      responsible for disputes arising from property conditions.
    </p>

    <h5 class="mt-3">Account Termination</h5>
    <p>
      MRV reserves the right to suspend or terminate accounts that violate 
      platform policies or engage in fraudulent activities.
    </p>
  </div>


  <div class="policy-card p-4 shadow-sm">
    <h3>Contact Us</h3>
    <p>
      If you have questions regarding our privacy policy or terms, please contact us:
    </p>

    <p>
      📧 Email: majesticrv2622@gmail.com <br>
      📍 Company: Majestic Rest Villas Private Limited
    </p>
  </div>

</div>