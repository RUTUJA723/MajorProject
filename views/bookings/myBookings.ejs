<% layout("/layouts/boilerplate") %>
<div class="mt-5">
    <h2 class="mb-4 text-center Myb">My Bookings</h2>

    <% if (bookings.length === 0) { %>
        <div class="alert alert-info text-center">
            You have no bookings yet.
        </div>
    <% } %>

   <div class="row">
  <% bookings.forEach(booking => { %>

    <div class="col-md-4 mb-4">
      <div class="card shadow-lg border-0 rounded-4">

        <!-- Listing Image -->
         <% if (booking.listing && booking.listing.image) { %>
        <img src="<%= booking.listing.image.url %>" 
             class="card-img-top" 
             style="height:250px; object-fit:cover; border-radius:15px 15px 0 0;">
             <% } %>

        <div class="card-body">

          <!-- Clickable Title -->
          <h5 class="card-title">
            <a href="/bookings/<%= booking.listing._id %>" 
               class="text-decoration-none text-dark">
              <%= booking.listing.title %>
            </a>
          </h5>

          <p><strong>Check-In:</strong> 
            <%= booking.checkIn.toDateString() %>
          </p>

          <p><strong>Check-Out:</strong> 
            <%= booking.checkOut.toDateString() %>
          </p>

          <p><strong>Total Price:</strong> ₹<%= booking.totalPrice %></p>

          <!-- Payment Status Badge -->
          <span class="badge 
            <%= booking.paymentStatus === 'paid' 
                ? 'bg-success' 
                : 'bg-warning text-dark' %>">
            <%= booking.paymentStatus %>
          </span>

          <!-- Cancel Button -->
          <form action="/bookings/<%= booking._id %>?_method=DELETE" method="POST" class="mt-3">
            <button class="btn btn-danger btn-sm">
              Cancel Booking
            </button>
          </form>
        </div>
      </div>
    </div>

  <% }) %>
</div>
</div>