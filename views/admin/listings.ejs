<%- include("../layouts/adminLayout") %>
<% layout("/layouts/boilerplate") %>

<h2 class="mb-4">All Listings</h2>

<div class="card shadow p-4">
  <% if(listings.length === 0){ %>
    <p>No listings found</p>
  <% } %>

  <% listings.forEach(listing => { %>
    <div class="border rounded p-3 mb-3">
      <img src="<%= listing.image.url?listing.image.url:'https://plus.unsplash.com/premium_photo-1681922761659-07483f67b6c7?q=80&w=687&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D' %>" class="card-img-top show-img" alt="listing_image">
      <h5><%= listing.title %></h5>
      <p><%= listing.location %></p>
      <p>₹ <%= listing.price %></p>
    </div>
  <% }) %>
</div>

</div>